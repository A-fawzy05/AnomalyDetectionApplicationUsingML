# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/p2p_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# App Settings
PROJECT_NAME="P2P Anomaly Detection API"
VERSION="1.0.0"
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=200
ALLOWED_ORIGINS=["*"]

# Model Settings
MODEL_DIR=artifacts/
LSTM_MAX_LEN=10

# Batch Processing
EVENT_LOG_BATCH_SIZE=1000
CASE_INSERT_BATCH_SIZE=500
